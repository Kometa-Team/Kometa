FROM python:3.13-slim

ARG BRANCH_NAME=claude/kometa-webui-settings-bwn2r
ENV BRANCH_NAME=${BRANCH_NAME}
ENV TINI_VERSION=v0.19.0
ENV KOMETA_DOCKER=True
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# System packages (same set as the main Dockerfile)
COPY requirements.txt /requirements.txt
RUN echo "**** install system packages ****" \
 && apt-get update \
 && apt-get upgrade -y --no-install-recommends \
 && apt-get install -y tzdata --no-install-recommends \
 && apt-get install -y gcc g++ libxml2-dev libxslt-dev libz-dev libjpeg62-turbo-dev zlib1g-dev wget curl nano \
 && wget -O /tini https://github.com/krallin/tini/releases/download/${TINI_VERSION}/tini-"$(dpkg --print-architecture | awk -F- '{ print $NF }')" \
 && chmod +x /tini \
 && pip3 install --no-cache-dir --upgrade --requirement /requirements.txt \
 && pip3 install --no-cache-dir flask>=3.0.0 \
 && apt-get --purge autoremove gcc g++ libxml2-dev libxslt-dev libz-dev -y \
 && apt-get clean \
 && rm -rf /requirements.txt /tmp/* /var/tmp/* /var/lib/apt/lists/*

COPY . /app
WORKDIR /app

VOLUME /config
EXPOSE 7799

ENTRYPOINT ["/tini", "-s", "python3", "webui/app.py", "--"]
CMD ["--host", "0.0.0.0", "--port", "7799"]
